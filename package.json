{
  "name": "video-commerce-mcp",
  "version": "0.2.0",
  "description": "Video Commerce Intelligence MCP Server - Extract commercial entities, score monetization, and discover market gaps from YouTube videos. Built for the agent-to-agent economy.",
  "type": "module",
  "license": "MIT",
  "author": "Since Today Studio <team@sincetoday.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/teamsincetoday/video-commerce-mcp.git"
  },
  "homepage": "https://github.com/teamsincetoday/video-commerce-mcp#readme",
  "bugs": {
    "url": "https://github.com/teamsincetoday/video-commerce-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "video-intelligence",
    "commerce",
    "youtube",
    "ner",
    "named-entity-recognition",
    "monetization",
    "x402",
    "entity-extraction",
    "ai-agent",
    "content-intelligence",
    "creator-tools",
    "affiliate-marketing",
    "agent-to-agent",
    "a2a",
    "claude",
    "market-intelligence"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "video-commerce-mcp": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "files": [
    "dist",
    "data/plant-dictionary-sample.json",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "SMOKE_TESTS=true vitest run src/__tests__/smoke",
    "eval": "tsx src/__tests__/eval/eval-cli.ts",
    "eval:live": "EVAL_LIVE=true tsx src/__tests__/eval/eval-cli.ts",
    "eval:update": "EVAL_UPDATE=true tsx src/__tests__/eval/eval-cli.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.6.2",
    "openai": "^6.25.0",
    "youtube-transcript": "^1.2.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@coinbase/x402": "^2.1.0"
  },
  "peerDependenciesMeta": {
    "@coinbase/x402": {
      "optional": true
    }
  }
}
