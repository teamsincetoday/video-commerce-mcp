# Video Commerce Intelligence MCP Server
# Copy this file to .env and fill in your values.

# =============================================================================
# REQUIRED
# =============================================================================

# OpenAI API key for NER extraction (GPT-4o-mini)
OPENAI_API_KEY=sk-...

# =============================================================================
# OPTIONAL: Cache Configuration
# =============================================================================

# Directory for SQLite analysis cache and usage database
# Default: ~/.video-commerce-mcp/
# ANALYSIS_CACHE_DIR=/path/to/cache

# Cache TTL in days (how long to keep cached analyses)
# Default: 7
# CACHE_TTL_DAYS=7

# =============================================================================
# OPTIONAL: x402 Payment Configuration
# =============================================================================

# Enable x402 micropayment verification
# Default: false
# X402_ENABLED=false

# Wallet address for receiving USDC payments (Base network)
# Required if X402_ENABLED=true
# X402_WALLET_ADDRESS=0x...

# x402 facilitator URL for payment verification
# Default: https://x402.org/facilitator
# X402_FACILITATOR_URL=https://x402.org/facilitator

# =============================================================================
# OPTIONAL: API Key Authentication (alternative to x402)
# =============================================================================

# Comma-separated list of valid API keys for authenticated access
# Clients send via X-API-Key header
# API_KEYS=key1,key2,key3

# =============================================================================
# OPTIONAL: Free Tier & Rate Limiting
# =============================================================================

# Free tier calls per day (per agent/IP, no auth required)
# Default: 5
# FREE_TIER_DAILY_LIMIT=5

# Rate limits (per agent)
# RATE_LIMIT_PER_MINUTE=30
# RATE_LIMIT_PER_HOUR=500
# RATE_LIMIT_PER_DAY=5000

# =============================================================================
# OPTIONAL: SSE Server Configuration
# =============================================================================

# Port for SSE transport (when running with --transport sse)
# Default: 3001
# PORT=3001
